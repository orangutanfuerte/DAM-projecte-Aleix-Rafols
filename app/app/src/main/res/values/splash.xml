<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.App.Starting" parent="android:Theme.Material.Light.NoActionBar">
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <!-- Set splash screen background color, drawable, etc. -->
        <item name="android:windowFullscreen">false</item>
        <!-- Optionally make status bar transparent or a custom color -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.TravelLikeASigma</item>
    </style>
</resources>
